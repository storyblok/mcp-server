# Storyblok API Configuration
# Get your token from: https://app.storyblok.com/#!/me/account?tab=token

# Required: Your Storyblok Personal Access Token
STORYBLOK_API_TOKEN=your_token_here

# Optional: Override the API base URL (region is auto-detected from space_id)
# STORYBLOK_API_URL=https://mapi.storyblok.com
