{
  "name": "storyblok-mcp",
  "version": "0.1.0",
  "description": "MCP Server for Storyblok API",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "storyblok-mcp": "bin/storyblok-mcp.js"
  },
  "files": [
    "bin",
    "src"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "openapi:fetch": "node --env-file=.env --import=tsx/esm scripts/openapi/fetch-spec.ts",
    "openapi:generate": "tsx scripts/openapi/apply-overlay.ts",
    "openapi:update": "npm run openapi:fetch && npm run openapi:generate",
    "test": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@storyblok/region-helper": "^1.3.1",
    "tsx": "^4.0.0",
    "oas": "^29.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "js-yaml": "^4.1.1",
    "openapi-overlays-js": "^0.2.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
